generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

model Category {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  price         Float
  originalPrice Float?
  imageUrl      String?
  isFeatured    Boolean  @default(false)
  isActive      Boolean  @default(true)
  stock         Int      @default(-1)
  
  categoryId  String   @db.ObjectId
  category    Category @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id             String   @id @map("_id") @default("main")
  popupImageUrl  String?
  popupLink      String?
  popupActive    Boolean  @default(false)
  
  ramadhanMode   Boolean  @default(false)
  countdownEnd   DateTime?
  showLiveSales  Boolean  @default(true)

  // Global Price Markup Settings
  globalMarkupType    String   @default("TIERED") // PERCENT, FIXED, or TIERED (legacy)
  globalMarkupPercent Float    @default(5.0)      // e.g. 5.0 for 5%
  globalMarkupFixed   Float    @default(2000)   // e.g. 2000 for Rp 2.000

  // Nickname Validator Settings (Cek ID)
  gameValidatorUrl    String   @default("https://api.vany.my.id/api/game/")

  updatedAt      DateTime @updatedAt
}

model Voucher {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  code          String   @unique
  discountType  String   @default("FIXED") // PERCENT or FIXED
  discountValue Float
  minPurchase   Float    @default(0)
  maxDiscount   Float?   // Cap for percentage discounts
  usageLimit    Int      @default(-1) // -1 for unlimited
  usedCount     Int      @default(0)
  isActive      Boolean  @default(true)
  expiryDate    DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TopupProduct {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  sku           String   @unique
  brand         String   
  name          String   
  price         Float    
  originalPrice Float    @default(0)
  category      String   @default("Games")
  type          String   @default("Umum")
  isActive      Boolean  @default(true)
  isGangguan    Boolean  @default(false)
  isFlashSale   Boolean  @default(false)
  flashSalePrice Float?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TopupTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String   @unique 
  gameId      String
  zoneId      String?
  sku         String
  productName String
  price       Float
  cost        Float?   @default(0) 
  discount    Float    @default(0)
  voucherId   String?  @db.ObjectId
  digiflazzNote String?  
  status      String   @default("PENDING") 
  snapToken   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GameConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  brand     String   @unique
  title     String?  // Display title (e.g., "Mobile Legends: Bang Bang")
  imageUrl  String?  // Vertical cover image
  iconUrl   String?  // Square/Circle icon
  category  String?  // Mobile, PC, Voucher, etc.
  isPopular Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
