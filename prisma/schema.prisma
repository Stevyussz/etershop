generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  price         Float
  originalPrice Float?
  imageUrl      String?
  isFeatured    Boolean  @default(false)
  isActive      Boolean  @default(true)
  stock         Int      @default(-1)
  
  categoryId  String   @db.ObjectId
  category    Category @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id             String   @id @map("_id") @default("main")
  popupImageUrl  String?
  popupLink      String?
  popupActive    Boolean  @default(false)
  
  ramadhanMode   Boolean  @default(false)
  countdownEnd   DateTime?
  showLiveSales  Boolean  @default(true)

  updatedAt      DateTime @updatedAt
}

model TopupProduct {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  sku           String   @unique
  brand         String   
  name          String   
  price         Float    
  originalPrice Float    @default(0)
  category      String   @default("Games")
  type          String   @default("Umum")
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TopupTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String   @unique 
  gameId      String
  zoneId      String?
  sku         String
  productName String
  price       Float
  cost        Float?   @default(0) 
  digiflazzNote String?  
  status      String   @default("PENDING") 
  snapToken   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
